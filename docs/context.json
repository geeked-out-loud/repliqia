{
  "project": {
    "name": "Repliqia",
    "type": "Distributed Key-Value Store",
    "description": "A Dynamo-style distributed storage system implementing vector-clock-based causality tracking, conflict detection, and eventual consistency across decentralized nodes.",
    "goal": "Demonstrate distributed systems concepts including replication, causal ordering, conflict resolution, and fault tolerance.",
    "positioning": "Causality-aware distributed replication engine with a versioned data model"
  },

  "core_concepts": {
    "consistency_model": "Eventual Consistency",
    "cap_theorem": "AP (Availability + Partition Tolerance)",
    "replication": "Multi-node replication with peer synchronization",
    "conflict_handling": "Multi-version storage (siblings) with client-side or system resolution",
    "causality_tracking": "Vector clocks"
  },

  "system_architecture": {
    "layers": {
      "core_distributed_layer": {
        "description": "Handles replication, vector clocks, conflict detection",
        "components": [
          "Node Service",
          "Replication Engine",
          "Vector Clock Engine",
          "Conflict Manager",
          "Local Storage"
        ]
      },
      "aggregation_layer": {
        "description": "Optional centralized database for analytics and querying",
        "role": "Read-only observer of resolved state",
        "db_options": ["PostgreSQL", "MongoDB"]
      }
    },

    "node_structure": {
      "node_id": "unique identifier per node",
      "local_store": "SQLite or JSON file",
      "vector_clock": "map of node_id to counter",
      "peers": "list of known nodes"
    }
  },

  "data_model": {
    "key_value_structure": {
      "key": "string",
      "value": "any JSON object",
      "metadata": {
        "vector_clock": {
          "node_id": "counter"
        },
        "timestamp": "optional",
        "node_origin": "node_id"
      }
    },

    "storage_format": {
      "example": {
        "user_123": [
          {
            "value": { "name": "Shubhan" },
            "clock": { "A": 2, "B": 1 }
          },
          {
            "value": { "name": "Shubhan_v2" },
            "clock": { "A": 1, "B": 2 }
          }
        ]
      },
      "note": "Multiple versions (siblings) allowed for conflicts"
    }
  },

  "vector_clock_logic": {
    "on_write": [
      "increment local node counter",
      "attach updated clock to value"
    ],
    "comparison_rules": {
      "A > B": "A happened after B",
      "A < B": "B happened after A",
      "concurrent": "no dominance → conflict"
    }
  },

  "operations": {
    "put": {
      "description": "Insert or update key",
      "steps": [
        "increment local vector clock",
        "store value with metadata",
        "replicate to peers"
      ]
    },

    "get": {
      "description": "Fetch value",
      "cases": [
        "single version → return value",
        "multiple versions → return all (conflict)"
      ]
    },

    "sync": {
      "description": "Peer-to-peer synchronization",
      "steps": [
        "exchange metadata",
        "compare vector clocks",
        "resolve ordering or detect conflict",
        "update local store"
      ]
    }
  },

  "conflict_resolution": {
    "strategy": "multi-version storage",
    "options": [
      "manual resolution",
      "last-write-wins (basic)",
      "merge function (advanced)"
    ],
    "example": {
      "input": ["value_A", "value_B"],
      "output": "merged_value"
    }
  },

  "failure_handling": {
    "node_failure": "node goes offline, others continue",
    "recovery": "node rejoins and syncs",
    "network_partition": "nodes diverge → later reconciliation",
    "guarantee": "eventual consistency"
  },

  "tech_stack": {
    "backend": ["Node.js (Express)", "or Python (Flask)"],
    "storage": ["SQLite (recommended)", "or JSON"],
    "communication": ["REST APIs", "or sockets"],
    "optional_db": ["PostgreSQL (aggregation layer)"]
  },

  "api_design": {
    "PUT /key": "write value",
    "GET /key": "read value(s)",
    "POST /sync": "synchronize with peer",
    "GET /clock": "get node vector clock",
    "GET /state": "debug current store"
  },

  "folder_structure": {
    "root": [
      "node/",
      "storage/",
      "clock/",
      "replication/",
      "api/",
      "utils/"
    ]
  },

  "team_roles": {
    "member_1": "Node service + API + storage",
    "member_2": "Vector clock engine + comparison logic",
    "member_3": "Replication + sync + conflict resolution"
  },

  "demo_scenarios": [
    {
      "name": "Sequential Update",
      "description": "A writes → B syncs → correct ordering"
    },
    {
      "name": "Concurrent Update",
      "description": "A and B write independently → conflict detected"
    },
    {
      "name": "Node Failure",
      "description": "B offline → A writes → B rejoins → sync"
    }
  ],

  "evaluation_metrics": {
    "conflict_detection_accuracy": "correctly identifies concurrent updates",
    "consistency": "eventual convergence",
    "replication_latency": "time to sync nodes",
    "fault_tolerance": "handles node failures"
  },

  "real_world_mapping": {
    "systems": ["Amazon Dynamo", "Cassandra", "Riak"],
    "use_cases": [
      "shopping carts",
      "offline-first apps",
      "distributed caching",
      "IoT systems"
    ]
  },

  "viva_points": [
    "vector clocks vs timestamps",
    "causal ordering",
    "eventual consistency",
    "conflict detection",
    "Dynamo reference"
  ]
}